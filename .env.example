# Copy to .env and fill in per deployment.
# Local development works without this file (sensible defaults are used).

# --- Django ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
SITE_URL=https://yourdomain.com

# --- Payment gateways ---
# Optional here: these can also be set per-store in admin → Site settings,
# which take precedence over these values.
STRIPE_API_KEY_PUBLISHABLE=
STRIPE_API_KEY_HIDDEN=
RAZORPAY_API_KEY_PUBLISHABLE=
RAZORPAY_API_KEY_HIDDEN=
PAYPAL_API_KEY_PUBLISHABLE=
PAYPAL_API_KEY_HIDDEN=
